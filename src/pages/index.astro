---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/Section.astro';
import Card from '../components/Card.astro';
import LinkList from '../components/LinkList.astro';
import Callout from '../components/Callout.astro';
import Icon from '../components/Icon.astro';
import siteData from '../content/site.json';

const page = siteData.pages.home;
---

<BaseLayout title={page.title} description={page.description}>
  <div class="hero">
    <h1>{page.hero.heading}</h1>
    <p>{page.hero.subheading}</p>
  </div>

  <Section id="essentials" heading="The Essentials">
    <div class="card-grid">
      {page.essentials.map((item) => (
        <Card
          icon={item.icon}
          title={item.title}
          description={item.description}
          bullets={item.bullets}
          links={item.links}
        />
      ))}
    </div>
  </Section>

  <Section id="alerts">
    <div class="section-heading-with-icon">
      <Icon name="bell" size={22} />
      <h2>{page.alertsAndApps.heading}</h2>
    </div>
    <p class="section-description">{page.alertsAndApps.description}</p>
    <Callout variant="warning">
      <p><Icon name="eye-off" size={16} /> <strong>Privacy note:</strong> {page.alertsAndApps.privacyNote}</p>
    </Callout>
    <LinkList links={page.alertsAndApps.links} />
  </Section>

  <Section id="official-weather">
    <div class="section-heading-with-icon">
      <Icon name="cloud-lightning" size={22} />
      <h2>{page.officialWeather.heading}</h2>
    </div>
    <p class="section-description">{page.officialWeather.description}</p>
    <LinkList links={page.officialWeather.links} />
  </Section>

  <Section
    id="official"
    heading={page.officialSources.heading}
    description={page.officialSources.description}
  >
    <LinkList links={page.officialSources.links} />
  </Section>

  <Section id="prep">
    <div class="section-heading-with-icon">
      <Icon name="shield" size={22} />
      <h2>{page.prep101.heading}</h2>
    </div>
    {page.prep101.sections.map((section) => (
      <div class="prep-block">
        <h3 class="prep-heading">
          {section.icon && <Icon name={section.icon} size={18} />}
          {section.title}
        </h3>
        <ul>
          {section.items.map((item) => <li>{item}</li>)}
        </ul>
        {section.links && section.links.length > 0 && (
          <div class="prep-links">
            {section.links.map((link) => (
              <a href={link.url} rel="noopener noreferrer" target="_blank">
                {link.label} <Icon name="arrow-up-right" size={14} />
              </a>
            ))}
          </div>
        )}
      </div>
    ))}
  </Section>

  <Section id="advanced">
    <div class="section-heading-with-icon">
      <Icon name="sparkles" size={22} />
      <h2>{page.advancedTips.heading}</h2>
    </div>
    <ul class="tips-list">
      {page.advancedTips.items.map((item) => <li>{item}</li>)}
    </ul>
  </Section>

  <Section id="meteorologists">
    <div class="section-heading-with-icon">
      <Icon name="users" size={22} />
      <h2>{page.meteorologists.heading}</h2>
    </div>
    <p class="section-description">{page.meteorologists.description}</p>
    <a href={page.meteorologists.listUrl} class="list-link" rel="noopener noreferrer" target="_blank">
      <Icon name="arrow-up-right" size={16} />
      {page.meteorologists.listLabel}
    </a>
  </Section>

  <Callout variant="info">
    <p><strong>Watch vs. Warning:</strong> A <em>Watch</em> means conditions are favorable for severe weather — stay alert. A <em>Warning</em> means severe weather is occurring or imminent — take shelter immediately.</p>
  </Callout>
</BaseLayout>
