---
const currentPath = Astro.url.pathname;
---

<header class="site-header">
  <div class="header-inner">
    <a href="/" class="wordmark">ARwx</a>
    <nav aria-label="Main navigation">
      <a href="/" class:list={[{ active: currentPath === '/' }]}>Readiness</a>
      <a href="/disaster-resources/" class:list={[{ active: currentPath.startsWith('/disaster-resources') }]}>Disaster Resources</a>
    </nav>
    <a href="https://x.com/araborwx" class="social-link" aria-label="Follow ARwx on X" rel="noopener noreferrer" target="_blank">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
      </svg>
    </a>
  </div>
</header>
