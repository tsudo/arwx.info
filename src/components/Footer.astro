---
import siteData from '../content/site.json';
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="footer-note">
    Not affiliated with any government agency. For informational purposes only.
  </div>
  <div class="footer-grid">
    <nav class="footer-nav" aria-label="Footer navigation">
      <a href="/">Readiness</a>
      <a href="/forecast/">Forecast</a>
      <a href="/disaster-resources/">Disaster Resources</a>
    </nav>
    <div class="footer-attribution">
      A <strong class="helpful-neighbor"><i class="fa-solid fa-hand-holding-heart" aria-hidden="true"></i> Helpful Neighbor</strong> project — <span class="built-by">built by</span> <a href={siteData.meta.authorUrl} target="_blank" rel="noopener">{siteData.meta.authorName}</a>
    </div>
    <div class="footer-license">
      &copy; {year} ARwx.info &middot; Licensed under <a href="https://creativecommons.org/licenses/by/4.0/" target="_blank" rel="noopener">CC BY 4.0</a>
    </div>
    <div class="footer-links">
      <a href={siteData.meta.suggestionsUrl} target="_blank" rel="noopener"><i class="fa-solid fa-message" aria-hidden="true"></i> Feedback</a>
      <a href={siteData.meta.kofiUrl} target="_blank" rel="noopener"><i class="fa-solid fa-mug-hot" aria-hidden="true"></i> Support on Ko-fi</a>
    </div>
  </div>
</footer>
