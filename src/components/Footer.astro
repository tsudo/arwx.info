---
import siteData from '../content/site.json';
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="footer-inner">
    <nav aria-label="Footer navigation">
      <a href="/">Readiness</a>
      <a href="/forecast/">Forecast</a>
      <a href="/disaster-resources/">Disaster Resources</a>
    </nav>
    <div class="footer-meta">
      <p>
        <a href={siteData.meta.suggestionsUrl} rel="noopener noreferrer" target="_blank">Suggest a correction</a>
        &middot;
        <a href={siteData.meta.repoUrl} rel="noopener noreferrer" target="_blank">GitHub</a>
        &middot;
        <a href={siteData.meta.kofiUrl} rel="noopener noreferrer" target="_blank">Support on Ko-fi</a>
      </p>
      <p class="footer-note">Not affiliated with any government agency. For informational purposes only.</p>
      <p class="footer-attribution">A Helpful Neighbor project by <a href={siteData.meta.authorUrl} rel="noopener noreferrer" target="_blank">{siteData.meta.authorName}</a></p>
      <p class="footer-tagline">Be Kind. Be Helpful.</p>
      <p class="footer-copyright">&copy; {year} ARwx.info</p>
      <p class="footer-license">
        This work is licensed under <a href="https://creativecommons.org/licenses/by/4.0/" rel="noopener noreferrer" target="_blank">CC BY 4.0</a>
        <img src="https://mirrors.creativecommons.org/presskit/icons/cc.svg" alt="" class="cc-icon" />
        <img src="https://mirrors.creativecommons.org/presskit/icons/by.svg" alt="" class="cc-icon" />
      </p>
    </div>
  </div>
</footer>
