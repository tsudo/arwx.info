  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill={filledIcons.has(name) ? 'currentColor' : 'none'}
  stroke={filledIcons.has(name) ? 'none' : 'currentColor'}
  stroke-width={filledIcons.has(name) ? '0' : '2'}
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
>
  <Fragment set:html={svgContent} />
</svg>
